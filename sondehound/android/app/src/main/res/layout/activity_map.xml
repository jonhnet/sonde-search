<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Mock button (debug only, floating top-left) -->
    <Button
        android:id="@+id/mockButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mock"
        android:visibility="gone"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:textColor="#FFAA00"
        android:layout_margin="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Mode selection bar -->
    <LinearLayout
        android:id="@+id/modeBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp"
        android:background="#DD444444"
        android:visibility="gone"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mode: "
            android:textColor="@android:color/white"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/modeSpinner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:id="@+id/frequencyLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:layout_marginStart="8dp">

            <EditText
                android:id="@+id/freqEditText"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:hint="403.000"
                android:inputType="numberDecimal"
                android:textColor="@android:color/white"
                android:textColorHint="#999999"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" MHz "
                android:textColor="@android:color/white"
                android:textSize="14sp" />

            <Button
                android:id="@+id/freqSubmitButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Set"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:textColor="@android:color/white" />
        </LinearLayout>
    </LinearLayout>

    <!-- Map (fills the middle) -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomPanel" />

    <!-- Map control buttons (floating) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_margin="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomPanel">

        <ImageView
            android:id="@+id/bleStatusIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:src="@drawable/ic_bluetooth"
            android:background="@drawable/fab_background"
            android:contentDescription="BLE status"
            android:scaleType="centerInside"
            android:padding="8dp" />

        <ImageButton
            android:id="@+id/centerUserButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:src="@android:drawable/ic_menu_mylocation"
            android:background="@drawable/fab_background"
            android:contentDescription="Center on me"
            android:scaleType="centerInside"
            android:padding="10dp" />

        <ImageButton
            android:id="@+id/centerSondeButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_balloon"
            android:background="@drawable/fab_background"
            android:contentDescription="Center on sonde"
            android:scaleType="centerInside"
            android:padding="10dp" />
    </LinearLayout>

    <!-- Bottom panel: bearing info + sonde list -->
    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="#DD333333"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/sondeListText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Searching for SondeHound..."
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:fontFamily="monospace" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
